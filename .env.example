SESSION_SECRET=change-me-to-a-long-random-string
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://deliverymanager:deliverymanager@postgres:5432/deliverymanager
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Host directory mounted into the backend container for local git workflows.
# Must match the parent path used in Admin → Mappings → Local project directory.
# LOCAL_PROJECTS_HOST_PATH=/var/www/html

# Delivery pipeline (Phase 2+)
JIRA_WRITEBACK_ENABLED=true
# Optional: Jira custom field id for Impact Analysis (e.g. customfield_10123). Leave empty to auto-discover by name.
JIRA_IMPACT_ANALYSIS_FIELD=
# Optional: Jira custom field id for Unit Testing Field. Leave empty to auto-discover by name.
JIRA_UNIT_TESTING_FIELD=
# Optional: Jira custom field id for Admin/ Database. Leave empty to auto-discover by name.
JIRA_ADMIN_DATABASE_FIELD=
